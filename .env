# TimeCapsule Environment Variables

# Backend Port
PORT=5000

# JSON Web Token Signature Key
JWT_SECRET=timecapsule_romantic_secret_key_987654321

# MongoDB Connection URI (Optional)
# If left blank or connection fails, the server will automatically fall back
# to a local file database stored in server/data/*.json
# MONGO_URI=mongodb://localhost:27017/timecapsule
MONGO_URI=
